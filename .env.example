# Discord webhook URL — required
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# RPC endpoints (defaults to public RPCs if not set)
ETHEREUM_RPC=https://eth.llamarpc.com
BASE_RPC=https://mainnet.base.org
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
UNICHAIN_RPC=https://mainnet.unichain.org

# How often to poll each chain (seconds, default: 30)
POLL_INTERVAL_SECONDS=30

# Path to the seen-auctions persistence file (default: ./seen-auctions.json)
STORAGE_PATH=./seen-auctions.json
